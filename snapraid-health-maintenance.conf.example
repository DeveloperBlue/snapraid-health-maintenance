# snapraid-health-maintenance.conf

# --- Notifications ---

# Required: where summary and alert emails are sent
EMAIL="you@example.com"

# useSend REST API (recommended)
# leave USESEND_API_URL empty to use mail only

USESEND_API_URL="https://send.example.com/api"
USESEND_FROM="snapraid@yourdomain.com"
USESEND_API_KEY="us_..."

# --- Paths ---

# Directory for daily run logs (default: /var/log/snapraid-health-maintenance)
LOG_DIR="/var/log/snapraid-health-maintenance"

# Delete logs older than this many days; set to 0 to disable rotation
LOG_RETENTION_DAYS=60

# SnapRAID binary path; leave empty to auto-detect on PATH
SNAPRAID_BIN=""

# smartctl binary path; leave empty to auto-detect on PATH
SMART_BIN=""

# --- SnapRAID maintenance ---

# Percentage of the array to scrub per weekly run (default: 20; full array over ~5 weeks)
SCRUB_PERCENT=20

# --- Health checks ---

# Warn when a mount on any physical disk reaches this usage %
DISK_USAGE_WARN_PERCENT=90

# SMART temperature warnings (°C)
SMART_TEMP_WARN_HDD=55
SMART_TEMP_WARN_SSD=70

# Mount paths to skip for usage warnings (still shown in disk space report).
# One quoted path per line.
DISK_USAGE_IGNORE_MOUNTS=(
    "/mnt/parity"
)
